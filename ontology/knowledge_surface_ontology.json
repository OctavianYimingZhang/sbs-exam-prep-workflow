{
  "schema_version": 1,
  "ontology_id": "knowledge_surface_ontology",
  "purpose": "Final student-facing rendering layer: convert internal knowledge plans into public notes or essays without exposing source-route narration, AI process, audit traces, or rigid template scaffolds.",
  "pipeline_position": [
    "AtomicKnowledgeLedger",
    "PublicKnowledgeUnit",
    "KnowledgeSurfaceContract",
    "NonKnowledgeGate",
    "SurfaceLabelDecision",
    "StudentFacingDocument"
  ],
  "routes": {
    "exam_prep_notes_docx": {
      "surface_mode": "compact_knowledge_notes",
      "label_policy": "semantic_sparse",
      "public_style": "black_arial_left_aligned_compact",
      "forbid_source_route_narration": true,
      "forbid_ai_process_provenance": true
    },
    "knowledge_walkthrough_docx": {
      "surface_mode": "lecture_first_knowledge_walkthrough",
      "label_policy": "semantic_sparse",
      "public_style": "black_arial_left_aligned_compact",
      "forbid_source_route_narration": true,
      "forbid_ai_process_provenance": true
    },
    "essay_exam_prep": {
      "surface_mode": "continuous_argumentative_essay",
      "budget_policy": "EssayAdaptiveBudget",
      "source_highlight_policy": "source_class_bound",
      "conclusion_required": true
    }
  },
  "allowed_public_functions": [
    "definition",
    "mechanism",
    "process",
    "method_workflow",
    "assay_readout",
    "calculation",
    "graph_data_rule",
    "diagnostic_rule",
    "comparison",
    "example_interpretation",
    "limitation_or_scope",
    "synthesis"
  ],
  "forbidden_public_functions": [
    "source_route_narration",
    "ai_process_or_provenance",
    "audit_trace",
    "generic_study_advice",
    "exam_meta_or_prediction_trace",
    "rigid_template_bucket",
    "evidence_justification_trace",
    "decorative_transition"
  ],
  "non_knowledge_patterns": {
    "source_route_narration": [
      "This slide shows",
      "The first slide shows",
      "The second slide shows",
      "The notes say",
      "According to page",
      "PPT page"
    ],
    "ai_process_or_provenance": [
      "AI generated",
      "ChatGPT generated",
      "I extracted",
      "English explanations extracted from",
      "This document was produced by"
    ],
    "audit_trace": [
      "source anchor",
      "source map",
      "qa flag",
      "run manifest",
      "confidence band",
      "evidence score"
    ]
  },
  "label_policy": {
    "default_mode": "semantic_sparse",
    "forbidden_repeated_template_labels": [
      "Definition",
      "Principle",
      "Mechanism",
      "Application",
      "Limitation",
      "Graph logic",
      "Interpretation",
      "Calculation logic"
    ],
    "labels_kept_when_semantically_necessary": [
      "Equation",
      "Worked example",
      "Diagnostic pattern",
      "Control",
      "Comparison",
      "Table"
    ],
    "decision_values": [
      "keep",
      "merge_into_heading",
      "merge_into_sentence",
      "delete"
    ]
  },
  "essay_adaptive_budget": {
    "object_type": "EssayAdaptiveBudget",
    "scope_values": [
      "single_concept",
      "one_lecture",
      "multi_lecture",
      "whole_module",
      "cross_module"
    ],
    "mechanism_detail_target_ratio": "0.10-0.15",
    "extra_reading_target_ratio": "0.10-0.15",
    "hard_word_count_floor_or_ceiling": false,
    "conclusion_required": true,
    "compression_policy": "expression_efficiency_not_fixed_count"
  },
  "essay_highlight_policy": {
    "extra_reading_book": "yellow",
    "extra_reading_paper": "green_with_parenthetical_author_year",
    "citation_original_source": "green_with_parenthetical_author_year",
    "classic_experiment_source": "green_with_parenthetical_author_year",
    "lecture_slide_core": "none"
  },
  "publish_gate": [
    "surface_function_scan",
    "non_knowledge_scan",
    "label_decision_scan",
    "route_style_scan",
    "essay_adaptive_budget_scan",
    "essay_source_highlight_scan"
  ]
}
